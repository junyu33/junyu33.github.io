pan&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;meta&quot;&gt;#&lt;span class=&quot;keyword&quot;&gt;ifdef&lt;/span&gt; __x86_64__&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;__attribute__((target(&lt;span class=&quot;string&quot;&gt;&quot;sse2,pclmul&quot;&lt;/span&gt;)))&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;meta&quot;&gt;#&lt;span class=&quot;keyword&quot;&gt;endif&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;keyword&quot;&gt;inline&lt;/span&gt; &lt;span class=&quot;type&quot;&gt;void&lt;/span&gt; &lt;span class=&quot;title function_&quot;&gt;gfmul&lt;/span&gt; &lt;span class=&quot;params&quot;&gt;(__m128i a, __m128i b, __m128i *res)&lt;/span&gt;{&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	__m128i tmp3, tmp6, tmp7, tmp8, tmp9, tmp10, tmp11, tmp12;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	__m128i XMMMASK = _mm_setr_epi32(&lt;span class=&quot;number&quot;&gt;0xffffffff&lt;/span&gt;, &lt;span class=&quot;number&quot;&gt;0x0&lt;/span&gt;, &lt;span class=&quot;number&quot;&gt;0x0&lt;/span&gt;, &lt;span class=&quot;number&quot;&gt;0x0&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	mul128(a, b, &amp;amp;tmp3, &amp;amp;tmp6);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp7 = _mm_srli_epi32(tmp6, &lt;span class=&quot;number&quot;&gt;31&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp8 = _mm_srli_epi32(tmp6, &lt;span class=&quot;number&quot;&gt;30&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp9 = _mm_srli_epi32(tmp6, &lt;span class=&quot;number&quot;&gt;25&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp7 = _mm_xor_si128(tmp7, tmp8);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp7 = _mm_xor_si128(tmp7, tmp9);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp8 = _mm_shuffle_epi32(tmp7, &lt;span class=&quot;number&quot;&gt;147&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp7 = _mm_and_si128(XMMMASK, tmp8);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp8 = _mm_andnot_si128(XMMMASK, tmp8);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp3 = _mm_xor_si128(tmp3, tmp8);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp6 = _mm_xor_si128(tmp6, tmp7);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp10 = _mm_slli_epi32(tmp6, &lt;span class=&quot;number&quot;&gt;1&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp3 = _mm_xor_si128(tmp3, tmp10);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp11 = _mm_slli_epi32(tmp6, &lt;span class=&quot;number&quot;&gt;2&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp3 = _mm_xor_si128(tmp3, tmp11);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp12 = _mm_slli_epi32(tmp6, &lt;span class=&quot;number&quot;&gt;7&lt;/span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	tmp3 = _mm_xor_si128(tmp3, tmp12);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	*res = _mm_xor_si128(tmp3, tmp6);&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;}&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
    
    </summary>
    
